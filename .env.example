PORT=3847
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Database (pick ONE) ──────────────────────────────────────────────────────
#
# Production / Coolify (recommended): PostgreSQL
# Create a PostgreSQL database in Coolify, then paste the connection string here:
#
#   DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Coolify shows this as "Postgres URL" or "Connection String" on the database
# resource page. Link the database to your app in Coolify UI — it injects
# DATABASE_URL automatically.
#
# Optional — only if your Postgres provider requires SSL:
#   DATABASE_SSL=true
#
# Local dev (no DATABASE_URL): SQLite file at data/licenses.db
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL=postgres://license:license@localhost:5432/license

# Comma-separated SHA-256 hashes of allowed APK signing certs (hex, lowercase).
# Leave empty to auto-detect on container start from keystore/APK (see below).
ALLOWED_APK_SIGNATURES=

# ── Auto ALLOWED_APK_SIGNATURES on deploy (pick ONE if ALLOWED_APK_SIGNATURES is empty) ──
#
# Best for Coolify: paste base64 of your release.keystore as a secret env var:
#   RELEASE_KEYSTORE_BASE64=<output of: base64 -i release.keystore | tr -d '\n'>
#   KEYSTORE_PASSWORD=senderid123
#   KEYSTORE_ALIAS=senderid
#
# Or mount the keystore file as a volume:
#   KEYSTORE_PATH=/secrets/release.keystore
#   KEYSTORE_PASSWORD=...
#   KEYSTORE_ALIAS=senderid
#
# Or point at a signed APK (path or base64):
#   RELEASE_APK_PATH=/secrets/SmsSenderIdInjector.apk
#   RELEASE_APK_BASE64=...
#
# Local one-liner to print the hash:
#   npm run extract-signature -- ../release.keystore senderid123 senderid

MIN_VERSION_CODE=1
INJECT_TOKEN_TTL_SEC=120
LICENSE_TOKEN_TTL_SEC=604800
HEARTBEAT_OFFLINE_GRACE_SEC=900
