PORT=3847
ADMIN_SECRET=change-me-to-a-long-random-string

# ── Database (pick ONE) ──────────────────────────────────────────────────────
#
# Production / Coolify (recommended): PostgreSQL
# Create a PostgreSQL database in Coolify, then paste the connection string here:
#
#   DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Coolify shows this as "Postgres URL" or "Connection String" on the database
# resource page. Link the database to your app in Coolify UI — it injects
# DATABASE_URL automatically.
#
# Optional — only if your Postgres provider requires SSL:
#   DATABASE_SSL=true
#
# Local dev (no DATABASE_URL): SQLite file at data/licenses.db
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL=postgres://license:license@localhost:5432/license

# Comma-separated SHA-256 hashes of allowed APK signing certs (hex, lowercase).
ALLOWED_APK_SIGNATURES=
MIN_VERSION_CODE=1
INJECT_TOKEN_TTL_SEC=120
LICENSE_TOKEN_TTL_SEC=604800
HEARTBEAT_OFFLINE_GRACE_SEC=900
